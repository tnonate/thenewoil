---
import { borderGradient, TEXT_GRADIENT_SECONDARY } from "@styles/common";
import { twJoin } from "tailwind-merge";

interface MemberLink {
  name: string;
  link: string;
  icon: string;
  icon_dark?: string;
}

interface Member {
  name: string;
  title: string;
  links: MemberLink[];
}

interface Props {
  members: Member[];
}

const { members } = Astro.props;
---

<ul class="grid grid-cols-1 gap-8 p-0 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" aria-label="Team">
  {
    members.map((member) => {
      return (
        <li
          class={borderGradient("flex flex-1 list-none flex-col items-center rounded-lg border-4 p-4 sm:items-start", {
            variant: "secondary",
            bgColor: "primary"
          })}
          aria-label="Member"
        >
          <div class="flex flex-col items-center justify-center sm:items-start">
            <p class="w-fit text-2xl font-semibold" aria-label="Name">
              {member.name}
            </p>
            <p class={twJoin("w-fit", TEXT_GRADIENT_SECONDARY)} aria-label="Function">
              {member.title}
            </p>
          </div>
          {member.links && (
            <ul class="flex items-center gap-4 p-0" aria-label="Links">
              {member.links.map((link) => {
                return (
                  <li class="list-none">
                    <a href={link.link} title={link.name}>
                      <img class="block h-12 w-12 rounded-xs" loading="lazy" alt={link.name} src={link.icon} />
                    </a>
                  </li>
                );
              })}
            </ul>
          )}
        </li>
      );
    })
  }
</ul>
