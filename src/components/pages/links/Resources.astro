---
import { textToHeadingId } from "@utils/heading";
import { Icon } from "astro-icon/components";

interface ResourceItem {
  name: string;
  link: string;
  custom_title?: string;
  author?: string;
}

interface Props {
  title: string;
  items: ResourceItem[];
}

const { title, items } = Astro.props;

const headingId = await textToHeadingId({
  text: title,
  prefix: "resource-"
});
---

<section class="w-full">
  <details class="group">
    <summary
      class="flex justify-between rounded-lg border-2 p-4
        border-black/10 bg-black/0 hover:border-black/0 hover:bg-black/5 group-open:border-black/0 group-open:bg-black/15 group-open:mb-3 motion-safe:transition-all
        dark:border-white/10 dark:bg-white/0 dark:hover:border-black/0 dark:hover:bg-white/5 dark:group-open:border-black/0 dark:group-open:bg-black/15
      "
    >
      <header>
        <h3 id={headingId}>{title}</h3>
      </header>

      <span>
        <Icon
          name="mdi:chevron-up"
          class="size-7 group-open:rotate-180 motion-safe:transition-all motion-safe:duration-200 motion-safe:ease-out"
          role="img"
          aria-label="Dropbown button icon"
        />
      </span>
    </summary>
    <ul class="-mt-3 p-4">
      {
        items.map((item) => {
          return (
            <li class="list-none" title={item.custom_title}>
              <a href={item.link} class="text-lg font-medium">
                {item.name}
              </a>
              {item.author && (
                <p aria-label="Author" class="opacity-70">
                  {item.author}
                </p>
              )}
            </li>
          );
        })
      }
    </ul>
  </details>
</section>
