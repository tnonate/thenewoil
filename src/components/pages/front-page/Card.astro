---
import Button, { type Variants } from "@components/controls/Button.astro";
import { borderGradient } from "@styles/common";

interface Props {
  title: string;
  description: string;
  link: string;
  color: Exclude<Variants['color'], undefined>;
  callToAction: string
}

const COLOR_CLASSES = {
  primary: borderGradient(undefined, { variant: "primary", bgColor: "primary" } ),
  secondary: borderGradient(undefined, { variant: "secondary", bgColor: "primary" } )
} as Record<Exclude<Variants['color'], undefined>, string>;

const { title, description, link, color, callToAction } = Astro.props;

const colorClasses = COLOR_CLASSES[color];
---

<article
  class={`hidden bg sm:flex min-w-[18rem] flex-1 flex-col items-center justify-between gap-8 border-4 px-4 py-12 text-center rounded-lg ${colorClasses}`}
>
  <h3 class="font-robotomono">{title}</h3>
  <p>{description}</p>
  <Button variant="contained" href={link} color={color} bgColor="primary" class="font-robotomono">{callToAction}</Button>
</article>

<Button
  variant="contained"
  href={link}
  color={color}
  bgColor="primary"
  class="flex h-24 w-full items-center justify-center p-1 font-robotomono text-sm xs:p-2 xs:text-base sm:hidden"
>
  {title}
</Button>
