---
import Card from "./Card.astro";

interface Item {
  title: string;
  description: string;
  link: string;
}

interface Props {
  items: Item[];
  color: "primary" | "secondary";
  callToAction: string;
}

const { items, color, callToAction } = Astro.props;
---

<div
  class="xs:gap-4 grid w-full grid-cols-2 justify-center gap-2 overflow-auto motion-safe:transition-all sm:gap-8 2xl:grid-cols-4"
>
  {
    items.map((item) => {
      return (
        <Card
          title={item.title}
          description={item.description}
          link={item.link}
          color={color}
          callToAction={callToAction}
        />
      );
    })
  }
</div>
