---
import { borderGradient } from "@styles/common";
import { textToHeadingId } from "@utils/heading";
import { twJoin } from "tailwind-merge";

interface Props {
  title: string;
}

const { title } = Astro.props;

const headingId = await textToHeadingId({
  text: title,
  prefix: "roadmap-item-"
});
---

<article class="flex min-h-16">
  <header class="hidden w-1/3 max-w-xs items-center break-all px-4 py-2 sm:flex sm:wrap-break-word">
    <h2 id={headingId} class="text-2xl font-medium">{title}</h2>
  </header>
  <div class="relative order-first w-0.5 bg-gradient-secondary-center sm:order-0" aria-hidden>
    <div
      class={twJoin(
        "absolute left-1/2 top-1/2 size-3 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-solid bg-primary dark:bg-primary-dark",
        borderGradient(undefined, { variant: "secondary", bgColor: "primary" })
      )}
    >
    </div>
  </div>
  <div class="flex flex-1 flex-col items-center gap-2 px-4 py-4 transition-all sm:flex-row sm:py-2">
    <header class="flex w-full items-center break-all sm:hidden sm:wrap-break-word">
      <h2 id={`${headingId}-mobile`} class="text-2xl font-medium">{title}</h2>
    </header>
    <slot />
  </div>
</article>
