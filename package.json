    "astro-compress": "^2.3.9",
    "astro-robots-txt": "^1.0.0",
    "esbuild": "^0.28.1",
    "linkedom": "^0.18.4",
    "node-fetch": "^3.3.0",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "string-strip-html": "^13.0.4",
    "svgo": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
